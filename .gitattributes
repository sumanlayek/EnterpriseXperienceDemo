###############################################################################
# Auto detect text files
###############################################################################
* text=auto

###############################################################################
# C#
###############################################################################
*.cs text diff=csharp

###############################################################################
# Solution / Project
###############################################################################
*.sln text
*.csproj text
*.props text
*.targets text

###############################################################################
# Scripts
###############################################################################
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

###############################################################################
# Linux scripts
###############################################################################
*.sh text eol=lf

###############################################################################
# Config
###############################################################################
*.json text
*.xml text
*.yml text
*.yaml text

###############################################################################
# Images
###############################################################################
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary

###############################################################################
# Fonts
###############################################################################
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

###############################################################################
# Archives
###############################################################################
*.zip binary